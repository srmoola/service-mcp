<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 px-4 py-8">
  <div class="text-center max-w-4xl mx-auto w-full">
    <!-- Service MCP Logo/Branding -->
    <div class="mb-8">
      <h1 class="text-6xl font-bold text-gray-900 mb-4">Multi-Repo Context Provider</h1>
      <p class="text-2xl text-gray-600 mb-2">Bridge AI Tools & Microservices Architecture</p>
      <p class="text-lg text-gray-500">Give your AI coding assistant system-wide context across all your repositories</p>
    </div>

    <% if user_signed_in? %>
      <!-- Authenticated User Section -->
      <div class="mb-8 bg-white rounded-lg shadow-lg p-6 border border-gray-200">
        <div class="flex items-center justify-center space-x-4 mb-4">
          <div class="flex items-center space-x-3">
            <% if current_user.avatar_url %>
              <img src="<%= current_user.avatar_url %>" alt="<%= current_user.name %>" class="w-12 h-12 rounded-full border-2 border-indigo-200">
            <% end %>
            <div class="text-left">
              <p class="text-lg font-semibold text-gray-900">Welcome back, <%= current_user.name %>!</p>
            </div>
          </div>
        </div>
        <%= link_to "Sign Out", logout_path, data: { "turbo-method": :delete }, 
                    class: "bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-lg transition-colors font-medium" %>
      </div>
    <% else %>
      <!-- Sign In Section - Centered -->
      <div class="mb-8">
        <p class="text-xl text-gray-700 mb-6">Sign in with GitHub to connect your repositories and generate your MCP server</p>
        <%= link_to "/auth/github", 
                    class: "bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-lg inline-flex items-center space-x-3 transition-colors text-lg font-medium shadow-lg hover:shadow-xl transform hover:scale-105" do %>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <span>Sign in with GitHub</span>
        <% end %>
      </div>
    <% end %>
    
    <% unless user_signed_in? %>
        <!-- Features Section -->
        <div class="grid md:grid-cols-3 gap-6 mt-12 max-w-5xl mx-auto">
        <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
            <div class="text-indigo-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">GitHub Integration</h3>
            <p class="text-gray-600">Connect your repositories and select which ones to include in your unified context.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
            <div class="text-indigo-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Smart Indexing</h3>
            <p class="text-gray-600">Automatically build unified context with cross-repo relationships and dependencies.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
            <div class="text-indigo-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">MCP Server</h3>
            <p class="text-gray-600">Generate MCP server links to plug into Cursor and other AI coding assistants.</p>
        </div>
        </div>
    <% end %>

    <% if user_signed_in? %>
      <!-- User Dashboard Section -->
      <div class="mt-12 bg-white rounded-lg shadow-lg p-8 max-w-3xl mx-auto border border-gray-200">
        <h3 class="text-2xl font-semibold text-gray-900 mb-6">Your MCP Dashboard</h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-4">
            <h4 class="font-medium text-gray-900 mb-2">Account Details</h4>
            <div class="space-y-1 text-sm text-gray-600">
              <p><strong>Name:</strong> <%= current_user.name %></p>
              <p><strong>Email:</strong> <%= current_user.email %></p>
              <p><strong>Provider:</strong> <%= current_user.provider.capitalize %></p>
            </div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <h4 class="font-medium text-gray-900 mb-2">Actions</h4>
            <div class="space-y-2">
              <%= link_to "Select Repositories", select_repositories_path, class: "w-full block text-center bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-4 py-2 rounded text-sm transition-colors" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
