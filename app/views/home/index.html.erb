<div class="container mx-auto px-4 py-8">
  <div class="text-center">
    <!-- Authentication Status -->
    <div class="mb-6 flex justify-end">
      <% if user_signed_in? %>
        <div class="flex items-center space-x-4">
          <div class="flex items-center space-x-2">
            <% if current_user.avatar_url %>
              <img src="<%= current_user.avatar_url %>" alt="<%= current_user.name %>" class="w-8 h-8 rounded-full">
            <% end %>
            <span class="text-gray-700">Hello, <%= current_user.name %>!</span>
          </div>
          <%= link_to "Sign Out", logout_path, method: :delete, 
                      class: "bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition-colors" %>
        </div>
      <% else %>
        <%= link_to "/auth/github", 
                    class: "bg-gray-900 hover:bg-gray-800 text-white px-6 py-3 rounded-lg inline-flex items-center space-x-2 transition-colors" do %>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <span>Sign in with GitHub</span>
        <% end %>
      <% end %>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 mb-4">Welcome to Your Rails Application</h1>
    <p class="text-xl text-gray-600 mb-8">
      <% if user_signed_in? %>
        You are now authenticated with GitHub and ready to access your repositories!
      <% else %>
        Sign in with GitHub to access your repositories and get started.
      <% end %>
    </p>
    
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 max-w-2xl mx-auto">
      <h2 class="text-2xl font-semibold text-blue-900 mb-3">
        <% if user_signed_in? %>
          GitHub Integration Active
        <% else %>
          Getting Started
        <% end %>
      </h2>
      <p class="text-blue-700">
        <% if user_signed_in? %>
          Your GitHub account is connected. You can now access your repositories and perform GitHub operations.
        <% else %>
          Sign in with GitHub above to connect your account and access your repositories.
        <% end %>
      </p>
    </div>

    <% if user_signed_in? %>
      <div class="mt-8 bg-green-50 border border-green-200 rounded-lg p-6 max-w-2xl mx-auto">
        <h3 class="text-lg font-semibold text-green-900 mb-2">Your GitHub Info</h3>
        <div class="text-left space-y-2 text-green-700">
          <p><strong>Name:</strong> <%= current_user.name %></p>
          <p><strong>Email:</strong> <%= current_user.email %></p>
          <p><strong>Provider:</strong> <%= current_user.provider.capitalize %></p>
          <p><strong>GitHub ID:</strong> <%= current_user.uid %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
